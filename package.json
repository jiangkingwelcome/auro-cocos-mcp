{
  "package_version": 2,
  "name": "aura-for-cocos",
  "version": "1.0.14",
  "title": "Aura for Cocos Creator",
  "description": "AI-powered Cocos Creator editor plugin — query, modify, and control your project via MCP",
  "author": "GameFlowEditor",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-panel-i18n.mjs",
    "watch": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "ci": "npm run typecheck && npm run lint && npm run coverage",
    "verify": "node scripts/verify-local.mjs",
    "build:release": "node scripts/build-release.mjs",
    "build:native": "node scripts/build-native.mjs",
    "build:native:release": "node scripts/build-native.mjs --release",
    "package:pro": "node scripts/package-pro.mjs",
    "install:global": "node scripts/install-global.js"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.0.18",
    "bytenode": "^1.5.7",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "javascript-obfuscator": "^5.3.0",
    "prettier": "^3.8.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.0"
  },
  "editor": ">=3.8.0",
  "main": "./dist/main.js",
  "panels": {
    "default": {
      "title": "Aura",
      "type": "dockable",
      "main": "./dist/panels/default/index.js",
      "size": {
        "min-width": 360,
        "min-height": 500,
        "width": 430,
        "height": 660
      }
    }
  },
  "contributions": {
    "menu": [
      {
        "path": "扩展",
        "label": "Aura",
        "message": "open-panel"
      }
    ],
    "messages": {
      "start-server": {
        "public": true,
        "description": "Start standalone MCP HTTP service",
        "methods": [
          "startServer"
        ]
      },
      "stop-server": {
        "public": true,
        "description": "Stop standalone MCP HTTP service",
        "methods": [
          "stopServer"
        ]
      },
      "restart-server": {
        "public": true,
        "description": "Restart standalone MCP HTTP service",
        "methods": [
          "restartServer"
        ]
      },
      "open-panel": {
        "public": true,
        "description": "Open status panel",
        "methods": [
          "openPanel"
        ]
      },
      "get-service-info": {
        "public": true,
        "description": "Get current service status info",
        "methods": [
          "getServiceInfo"
        ]
      },
      "configure-ide": {
        "public": true,
        "description": "One-click configure IDE MCP",
        "methods": [
          "configureIDE"
        ]
      },
      "remove-ide": {
        "public": true,
        "description": "Remove IDE MCP configuration",
        "methods": [
          "removeIDE"
        ]
      },
      "get-settings": {
        "public": true,
        "description": "Get bridge settings",
        "methods": [
          "getSettings"
        ]
      },
      "update-settings": {
        "public": true,
        "description": "Update bridge settings",
        "methods": [
          "updateSettings"
        ]
      },
      "set-tool-enabled": {
        "public": true,
        "description": "Enable or disable a specific MCP tool",
        "methods": [
          "setToolEnabled"
        ]
      },
      "reset-settings": {
        "public": true,
        "description": "Reset bridge settings to defaults",
        "methods": [
          "resetSettings"
        ]
      },
      "get-license-status": {
        "public": true,
        "description": "Get Pro license activation status",
        "methods": [
          "getLicenseStatus"
        ]
      },
      "activate-license": {
        "public": true,
        "description": "Activate Pro license with a key",
        "methods": [
          "activateLicense"
        ]
      },
      "check-for-updates": {
        "public": true,
        "description": "Check GitHub for plugin updates",
        "methods": [
          "checkForUpdates"
        ]
      },
      "download-update": {
        "public": true,
        "description": "Download the available update package",
        "methods": [
          "downloadUpdate"
        ]
      },
      "install-update": {
        "public": true,
        "description": "Apply the downloaded update and backup current version",
        "methods": [
          "installUpdate"
        ]
      },
      "reset-update-state": {
        "public": true,
        "description": "Reset the updater state to idle",
        "methods": [
          "resetUpdateState"
        ]
      },
      "scene:ready": {
        "methods": [
          "onSceneReady"
        ]
      }
    },
    "scene": {
      "script": "./dist/scene.js"
    }
  }
}
